# Database (used by docker-compose to create PostgreSQL + by backend to connect)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=expenseguard

# Backend reads this (docker-compose builds it automatically, but set it for local dev)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/expenseguard

# JWT auth
SECRET_KEY=change-this-to-a-long-random-string

# OpenAI (for AI Advisor feature)
OPENAI_API_KEY=sk-your-key-here
